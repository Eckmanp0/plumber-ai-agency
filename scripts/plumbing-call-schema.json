{
  "name": "plumbing-call-structured-output",
  "type": "ai",
  "description": "Extract normalized customer, job, and outcome details from a plumbing intake call.",
  "schema": {
    "type": "object",
    "properties": {
      "customer": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "phone": { "type": "string" },
          "service_address": { "type": "string" }
        },
        "required": ["name", "phone"]
      },
      "job": {
        "type": "object",
        "properties": {
          "issue_description": { "type": "string" },
          "service_type": {
            "type": "string",
            "enum": [
              "drain_cleaning",
              "leak_repair",
              "water_heater",
              "toilet",
              "faucet",
              "sewer",
              "garbage_disposal",
              "repiping",
              "other"
            ]
          },
          "urgency": {
            "type": "string",
            "enum": ["low", "medium", "high", "emergency"]
          },
          "bookable": { "type": "boolean" }
        },
        "required": ["issue_description", "service_type", "urgency"]
      },
      "outcome": {
        "type": "object",
        "properties": {
          "call_outcome": {
            "type": "string",
            "enum": [
              "booked",
              "pending_confirmation",
              "callback_required",
              "out_of_area",
              "service_not_offered",
              "spam",
              "wrong_number"
            ]
          },
          "summary": { "type": "string" },
          "follow_up_required": { "type": "boolean" }
        },
        "required": ["call_outcome", "summary"]
      }
    },
    "required": ["customer", "job", "outcome"]
  }
}
